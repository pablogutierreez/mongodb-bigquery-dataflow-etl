# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored so your secrets never get committed.

# MongoDB connection string (Atlas or self-hosted).
export MONGO_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority"

# MongoDB database to read from.
export MONGO_DB="mydb"

# Comma-separated list of collections to sync.
# Note that after this, you can add in Main.py a projection of the fields you want to sync for each collection, to avoid syncing unnecessary data.

export COLLECTIONS="users,orders,products"

# GCP project that owns the Dataflow job and BigQuery dataset.
export GOOGLE_CLOUD_PROJECT="my-gcp-project"

# Region for Dataflow, Workflows and Scheduler.
export REGION="europe-west1"

# BigQuery dataset to write the tables into (must already exist).
export BQ_DATASET="mongo_data"

# GCS bucket (no gs:// prefix) used for Dataflow staging/temp and the template.
export GCS_BUCKET="my-dataflow-staging-bucket"

# Service account the Dataflow workers run as.
export RUNTIME_SA="mongo-bq-etl@my-gcp-project.iam.gserviceaccount.com"

# Pub/Sub topic for dead-letter messages (leave empty to log failures only).
export DLQ_TOPIC="projects/my-gcp-project/topics/mongo-etl-dlq"
